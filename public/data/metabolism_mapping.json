        "Eubacterium",
        "Bifidobacterium",
        "Akkermansia",
        "Coprococcus",
        "Butyrivibrio",
        "Anaerostipes",
        "Subdoligranulum",
        "Ruminococcus"
      ],
      "key_metabolites": [
        "Butyrate",
        "Propionate",
        "Acetate"
      ],
      "related_pathways": [
        "Pyruvate fermentation",
        "Wood-Ljungdahl pathway",
        "Acrylate pathway"
