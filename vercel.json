{
  "rewrites": [
    { "source": "/api", "destination": "https://78c3fda.r20.vip.cpolar.cn/api" },
    { "source": "/api/(.*)", "destination": "https://78c3fda.r20.vip.cpolar.cn/api/$1" },
    { "source": "/((?!api(?:/|$)|data(?:/|$)|assets(?:/|$)|favicon\\.ico$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=600" }
      ]
    }
  ]
}
